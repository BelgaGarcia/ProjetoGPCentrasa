@using CentraSA.Application.Insights
@using CentraSA.Domain.Enums
@model DashboardData
@{
    ViewData["Title"] = "Visão executiva";
    static string SourceController(TrackedEntityType sourceType) => sourceType switch
    {
        TrackedEntityType.PendingTask => "PendingTasks",
        TrackedEntityType.Smud => "Smuds",
        TrackedEntityType.SupportTicket => "SupportTickets",
        _ => "Home",
    };
}

<header class="page-header dashboard-header">
    <div class="page-header__copy">
        <span class="eyebrow">Dados consolidados do banco</span>
        <h1>Visão executiva</h1>
        <p>Prioridades, prazos e movimentações recentes dos três módulos operacionais.</p>
    </div>
    <div class="page-actions">
        <a class="button button--secondary" asp-controller="History" asp-action="Index">Histórico global</a>
        <a class="button button--primary" asp-controller="DailyMeetings" asp-action="Create">Preparar reunião</a>
    </div>
</header>

<section class="dashboard-metrics" aria-label="Contadores operacionais">
    <a class="surface-card dashboard-metric dashboard-metric--blue" asp-controller="Dashboard" asp-action="Items" asp-route-SourceType="PendingTask" asp-route-State="Active">
        <span>Pendências ativas</span><strong>@Model.ActivePendingTasks</strong><small>Abrir listagem filtrada</small>
    </a>
    <a class="surface-card dashboard-metric dashboard-metric--purple" asp-controller="Dashboard" asp-action="Items" asp-route-SourceType="Smud" asp-route-State="Active">
        <span>SMUDs ativos</span><strong>@Model.ActiveSmuds</strong><small>Abrir listagem filtrada</small>
    </a>
    <a class="surface-card dashboard-metric dashboard-metric--cyan" asp-controller="Dashboard" asp-action="Items" asp-route-SourceType="SupportTicket" asp-route-State="Active">
        <span>Chamados ativos</span><strong>@Model.ActiveSupportTickets</strong><small>Abrir listagem filtrada</small>
    </a>
    <a class="surface-card dashboard-metric dashboard-metric--red" asp-controller="Dashboard" asp-action="Items" asp-route-State="Overdue">
        <span>Itens atrasados</span><strong>@Model.OverdueCount</strong><small>Prazo anterior a hoje</small>
    </a>
    <a class="surface-card dashboard-metric dashboard-metric--yellow" asp-controller="Dashboard" asp-action="Items" asp-route-State="DueSoon">
        <span>Próximos 7 dias</span><strong>@Model.DueSoonCount</strong><small>Hoje também está incluído</small>
    </a>
    <a class="surface-card dashboard-metric dashboard-metric--green" asp-controller="Dashboard" asp-action="Items" asp-route-State="RecentlyCompleted">
        <span>Concluídos recentes</span><strong>@Model.RecentlyCompletedCount</strong><small>Últimos 7 dias</small>
    </a>
</section>

<section class="dashboard-columns">
    <article class="surface-card dashboard-panel" aria-labelledby="deadlines-title">
        <header class="section-heading">
            <div><span class="eyebrow">Ordem cronológica</span><h2 id="deadlines-title">Prazos prioritários</h2></div>
            <a asp-controller="Dashboard" asp-action="Items" asp-route-State="Active">Ver todos</a>
        </header>
        @if (Model.Deadlines.Count == 0)
        {
            <div class="dashboard-empty"><p>Nenhum prazo ativo registrado.</p></div>
        }
        else
        {
            <ol class="dashboard-deadlines">
                @foreach (var item in Model.Deadlines)
                {
                    <li class="@(item.IsOverdue ? "is-overdue" : item.IsDueSoon ? "is-soon" : string.Empty)">
                        <time>@item.DueDate?.ToString("dd/MM")</time>
                        <div><span>@item.SourceLabel · @item.Reference</span><strong>@item.Title</strong><small>@item.Status</small></div>
                        <a asp-controller="@SourceController(item.SourceType)" asp-action="Details" asp-route-id="@item.SourceId" aria-label="Abrir @item.Title">Abrir</a>
                    </li>
                }
            </ol>
        }
    </article>

    <article class="surface-card dashboard-panel" aria-labelledby="activity-title">
        <header class="section-heading">
            <div><span class="eyebrow">Auditoria básica</span><h2 id="activity-title">Atividade recente</h2></div>
            <a asp-controller="History" asp-action="Index">Ver histórico</a>
        </header>
        @if (Model.RecentActivity.Count == 0)
        {
            <div class="dashboard-empty"><p>Nenhuma atividade registrada.</p></div>
        }
        else
        {
            <ol class="dashboard-activity">
                @foreach (var entry in Model.RecentActivity)
                {
                    <li>
                        <span class="dashboard-activity__marker" aria-hidden="true"></span>
                        <div><span>@entry.EntityLabel · @entry.ActionLabel</span><strong>@entry.Summary</strong><time>@entry.OccurredAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</time></div>
                        <a asp-controller="History" asp-action="Details" asp-route-entityType="@entry.EntityType" asp-route-id="@entry.EntityId">Detalhes</a>
                    </li>
                }
            </ol>
        }
    </article>
</section>

<section class="surface-card dashboard-meeting-callout">
    <div><span class="eyebrow">Reunião diária</span><h2>@Model.DraftMeetingCount rascunho(s) em andamento</h2><p>Continue uma sessão preparada ou monte a próxima pauta.</p></div>
    <a class="button button--ghost" asp-controller="DailyMeetings" asp-action="Index">Abrir reuniões</a>
</section>
