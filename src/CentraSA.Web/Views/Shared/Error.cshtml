@model ErrorViewModel
@{
    ViewData["Title"] = "Não foi possível concluir";
}

<section class="error-state">
    <div class="error-state__content">
        <span class="error-state__icon" aria-hidden="true"><svg class="icon"><use href="#icon-alert"></use></svg></span>
        <span class="eyebrow">Erro inesperado</span>
        <h1>Não foi possível processar sua solicitação.</h1>
        <p>Tente novamente. Se o problema continuar, reinicie a aplicação e consulte o terminal sem compartilhar informações sensíveis.</p>
        @if (Model.ShowRequestId)
        {
            <p><strong>Identificador:</strong> <code>@Model.RequestId</code></p>
        }
        <a asp-controller="Home" asp-action="Index" class="button button--primary">Voltar ao início</a>
    </div>
</section>
