@model CentraSA.Web.ViewModels.Lookups.LookupFormViewModel
@{
    ViewData["Title"] = "Editar cadastro auxiliar";
}
<header class="page-header"><div class="page-header__copy"><span class="eyebrow">Configuração</span><h1>Editar cadastro auxiliar</h1></div></header>
<form asp-action="Edit" asp-route-kind="@Model.Kind" asp-route-id="@Model.Id" method="post" class="surface-card lookup-form"><partial name="_Form" model="Model" /><div class="form-actions"><button class="button button--primary" type="submit">Atualizar cadastro</button><a class="button button--ghost" asp-action="Index">Cancelar</a></div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
