@using CentraSA.Domain.Enums
@model CentraSA.Application.PendingTasks.PendingTaskDetailsData
@{
    ViewData["Title"] = "Detalhes da pendência";
    string priority = Model.Item.Priority switch
    {
        PriorityLevel.Low => "Baixa",
        PriorityLevel.Medium => "Média",
        PriorityLevel.High => "Alta",
        PriorityLevel.Critical => "Crítica",
        _ => Model.Item.Priority.ToString(),
    };
}

<header class="page-header">
    <div class="page-header__copy">
        <span class="eyebrow">Pendência</span>
        <h1>@Model.Item.Title</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Item.Description))
        {
            <p>@Model.Item.Description</p>
        }
    </div>
    <div class="page-actions">
        <a class="button button--ghost" asp-action="Index">Voltar</a>
        @if (!Model.ArchivedAtUtc.HasValue)
        {
            <a class="button button--primary" asp-action="Edit" asp-route-id="@Model.Item.Id">Editar</a>
        }
    </div>
</header>

<div class="details-grid">
    <section class="surface-card detail-card" aria-labelledby="detail-summary-title">
        <h2 id="detail-summary-title">Acompanhamento</h2>
        <dl class="detail-list">
            <div><dt>Status</dt><dd><span class="status-badge" data-status-color="@Model.Item.StatusColor">@Model.Item.Status</span></dd></div>
            <div><dt>Área</dt><dd>@Model.Item.Area</dd></div>
            <div><dt>Responsável</dt><dd>@(Model.Item.Person ?? "Não definido")</dd></div>
            <div><dt>Prioridade</dt><dd>@priority</dd></div>
            <div><dt>Prazo</dt><dd>@(Model.Item.DueDate?.ToString("dd/MM/yyyy") ?? "Sem prazo")</dd></div>
            <div><dt>Vínculo</dt><dd>@(Model.Item.RelatedItem ?? "Nenhum")</dd></div>
            <div><dt>Origem</dt><dd>@(Model.Origin ?? "Não informada")</dd></div>
            <div><dt>Criada em</dt><dd>@Model.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd></div>
        </dl>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="detail-notes"><strong>Observações</strong><p>@Model.Notes</p></div>
        }
        @if (Model.ArchivedAtUtc.HasValue)
        {
            <div class="app-alert app-alert--danger"><div><strong>Item arquivado</strong><p>Restaure-o na tela de arquivadas para voltar a editá-lo.</p></div></div>
        }
    </section>

    <section class="surface-card detail-card" aria-labelledby="history-title">
        <h2 id="history-title">Histórico</h2>
        @if (Model.History.Count == 0)
        {
            <p>Nenhum evento registrado.</p>
        }
        else
        {
            <ol class="history-timeline">
                @foreach (var history in Model.History)
                {
                    <li>
                        <span aria-hidden="true"></span>
                        <div><strong>@history.Action</strong><p>@history.Summary</p><time>@history.OccurredAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</time></div>
                    </li>
                }
            </ol>
        }
    </section>
</div>
