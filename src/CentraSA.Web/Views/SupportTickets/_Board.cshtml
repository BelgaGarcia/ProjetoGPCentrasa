@using CentraSA.Domain.Enums
@model CentraSA.Web.ViewModels.SupportTickets.SupportTicketIndexViewModel
@{
    static string PriorityLabel(PriorityLevel priority) => priority switch
    {
        PriorityLevel.Low => "Baixa",
        PriorityLevel.Medium => "Média",
        PriorityLevel.High => "Alta",
        PriorityLevel.Critical => "Crítica",
        _ => priority.ToString(),
    };
}

<div class="ticket-board-summary">
    <p><strong>@Model.Data.TotalCount</strong> @(Model.Data.TotalCount == 1 ? "chamado exibido" : "chamados exibidos")</p>
    <ul class="ticket-legend" aria-label="Legenda de categorias">
        @foreach (var category in Model.Data.Options.Categories)
        {
            <li><span class="status-badge" data-status-color="@category.ColorToken">@category.Name</span></li>
        }
    </ul>
</div>

@if (Model.Data.TotalCount == 0)
{
    <div class="empty-state">
        <span class="empty-state__icon" aria-hidden="true"><svg class="icon"><use href="#icon-ticket"></use></svg></span>
        <h2>@(Model.Data.ArchivedOnly ? "Nenhum chamado arquivado" : "Nenhum chamado encontrado")</h2>
        <p>@(Model.Data.ArchivedOnly ? "Os chamados arquivados aparecerão aqui." : "Ajuste os filtros ou registre o primeiro chamado.")</p>
        @if (!Model.Data.ArchivedOnly)
        {
            <a class="button button--primary" asp-action="Create">Criar chamado</a>
        }
    </div>
}
else
{
    <div class="ticket-board" aria-label="Chamados agrupados por categoria">
        @foreach (var group in Model.Data.Groups.Where(group => group.Total > 0))
        {
            <section class="ticket-group surface-card" aria-labelledby="ticket-group-@group.CategoryId">
                <header class="ticket-group__header">
                    <div><span class="smud-column__indicator" data-status-color="@group.ColorToken" aria-hidden="true"></span><h2 id="ticket-group-@group.CategoryId">@group.Category</h2></div>
                    <span class="smud-column__total">@group.Total</span>
                </header>
                <ol class="ticket-relations">
                    @foreach (var item in group.Cards)
                    {
                        <li>
                            <article class="ticket-relation @(item.IsOverdue ? "is-overdue" : string.Empty)">
                                <div class="ticket-node ticket-node--card">
                                    <div class="ticket-node__topline">
                                        <a class="ticket-number" asp-action="Details" asp-route-id="@item.Id">Chamado @item.Number</a>
                                        <span class="status-badge" data-status-color="@item.StatusColor">@item.Status</span>
                                    </div>
                                    <h3><a asp-action="Details" asp-route-id="@item.Id">@item.Title</a></h3>
                                    <span class="priority-chip priority-chip--@item.Priority.ToString().ToLowerInvariant()">Prioridade @PriorityLabel(item.Priority)</span>
                                    @if (!string.IsNullOrWhiteSpace(item.PendingAction))
                                    {
                                        <div class="ticket-action"><strong>Ação pendente</strong><p>@item.PendingAction</p></div>
                                    }
                                    <div class="ticket-node__actions" data-no-print>
                                        @if (Model.Data.ArchivedOnly)
                                        {
                                            <form asp-action="Restore" asp-route-id="@item.Id" method="post">
                                                <input type="hidden" name="version" value="@item.Version" />
                                                <button class="button button--secondary button--compact" type="submit">Restaurar</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a class="button button--ghost button--compact" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                                            <form asp-action="Archive" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Arquivar este chamado?');">
                                                <input type="hidden" name="version" value="@item.Version" />
                                                <button class="button button--ghost button--compact" type="submit">Arquivar</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                                <span class="ticket-connector" aria-hidden="true"></span>
                                <div class="ticket-node ticket-node--responsible">
                                    <span class="ticket-node__label">Responsável</span>
                                    <strong>@item.Area</strong>
                                    <small>@(item.Person ?? "Pessoa não definida")</small>
                                </div>
                                <span class="ticket-connector" aria-hidden="true"></span>
                                <div class="ticket-node ticket-node--deadline @(item.IsOverdue ? "is-overdue" : item.IsDueSoon ? "is-soon" : string.Empty)">
                                    <span class="ticket-node__label">Prazo</span>
                                    <strong>@(item.DueDate?.ToString("dd/MM/yyyy") ?? "Sem prazo")</strong>
                                    <small>@(item.IsOverdue ? "Atrasado" : item.IsDueSoon ? "Vence em breve" : $"Aberto em {item.OpenedOn:dd/MM/yyyy}")</small>
                                </div>
                            </article>
                        </li>
                    }
                </ol>
            </section>
        }
    </div>
}
