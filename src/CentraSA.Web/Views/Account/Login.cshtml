@model CentraSA.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <h1 class="h2">Entrar</h1>
        <p>Acesso local à Central CentraSA.</p>

        @if (TempData["SuccessMessage"] is string message)
        {
            <div class="alert alert-success" role="status">@message</div>
        }

        <form method="post" novalidate>
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary">Entrar</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
