@model CentraSA.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
}

<article class="auth-card">
    <header class="auth-card__header">
        <span class="eyebrow">Acesso seguro</span>
        <h1>Bem-vindo de volta</h1>
        <p>Entre com o administrador configurado nesta máquina.</p>
    </header>

    <form method="post" class="auth-form" novalidate>
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" role="alert"></div>
        <div class="field-group">
            <label asp-for="UserName" class="form-label"></label>
            <input asp-for="UserName" class="form-control" autocomplete="username" autofocus />
            <span asp-validation-for="UserName"></span>
        </div>
        <div class="field-group">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Password"></span>
        </div>
        <div class="form-check mb-3">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label"></label>
        </div>
        <button type="submit" class="button button--primary button--block">Entrar</button>
    </form>

    <p class="auth-card__footer">A aplicação aceita conexões apenas da máquina local.</p>
</article>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
