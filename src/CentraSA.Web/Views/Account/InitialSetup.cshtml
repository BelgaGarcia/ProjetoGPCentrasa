@model CentraSA.Web.ViewModels.Account.InitialSetupViewModel
@{
    ViewData["Title"] = "Configuração inicial";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">
        <h1 class="h2">Configuração inicial</h1>
        <p>Crie o único administrador local. Não existe senha padrão.</p>

        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-text">Use ao menos 12 caracteres, incluindo letras minúsculas e números.</div>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Criar administrador</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
