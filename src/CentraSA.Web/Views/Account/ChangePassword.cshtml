@model CentraSA.Web.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Alterar senha";
    var header = new PageHeaderViewModel(
        "Alterar senha",
        "Atualize a credencial do administrador local.",
        "Minha conta");
}

<partial name="_PageHeader" model="header" />

<section class="surface-card form-card">
    <form asp-action="ChangePassword" method="post" novalidate>
        <div asp-validation-summary="All" role="alert"></div>
        <div class="field-group">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="CurrentPassword"></span>
        </div>
        <div class="field-group">
            <label asp-for="NewPassword" class="form-label"></label>
            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="NewPassword"></span>
        </div>
        <div class="field-group">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword"></span>
        </div>
        <button type="submit" class="button button--primary">Salvar nova senha</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
