@model CentraSA.Web.ViewModels.Smuds.SmudIndexViewModel
@{
    ViewData["Title"] = "SMUDs arquivados";
}

<partial name="_PageHeader" model="@(new PageHeaderViewModel("SMUDs arquivados", "Consulte customizações retiradas do quadro e restaure-as quando necessário.", "Arquivo", "Voltar aos SMUDs", Url.Action("Index"), "arrow-right"))" />

<form method="get" class="surface-card task-filters task-filters--compact" data-async-filter data-target="#smud-board-results">
    <div class="task-filters__search">
        <label for="smud-search">Buscar no arquivo</label>
        <input id="smud-search" asp-for="Search" class="form-control"
               placeholder="Código, título, descrição ou ação" data-filter-search />
    </div>
    <div>
        <label asp-for="AreaId">Área</label>
        <select asp-for="AreaId" class="form-select">
            <option value="">Todas</option>
            @foreach (var area in Model.Data.Options.Areas)
            {
                <option value="@area.Id">@area.Name</option>
            }
        </select>
    </div>
    <button type="submit" class="button button--secondary">Filtrar</button>
    <a asp-action="Archived" class="button button--ghost">Limpar</a>
</form>

<div id="smud-board-results" aria-live="polite">
    <partial name="_Board" model="Model" />
</div>
